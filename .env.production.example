# Copy to .env.production.local for running prod scripts against live Supabase.
# Pull from Vercel: npx vercel env pull .env.production.local --environment=production

DATABASE_PROVIDER=supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: auto-apply schema/migration via npm run db:migrate
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Korona + ShipHero (same as production Vercel env)
KORONA_ACCOUNT_ID=
KORONA_USERNAME=
KORONA_PASSWORD=
KORONA_WAREHOUSE_ID=
SHIPHERO_REFRESH_TOKEN=
SHIPHERO_WAREHOUSE_ID=
CRON_SECRET=

# Then run:
# npm run prod:link -- --cache-pages=20 --index-pages=100
# npm run prod:remote-link -- --url https://merchantshiphero.com
