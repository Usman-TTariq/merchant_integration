# Korona Cloud API v3
KORONA_BASE_URL=https://185.koronacloud.com/web/api/v3
KORONA_ACCOUNT_ID=your-account-uuid
KORONA_USERNAME=your-api-login
KORONA_PASSWORD=your-api-password

# ShipHero GraphQL Public API
SHIPHERO_AUTH_URL=https://public-api.shiphero.com/auth/token
SHIPHERO_REFRESH_URL=https://public-api.shiphero.com/auth/refresh
SHIPHERO_GRAPHQL_URL=https://public-api.shiphero.com/graphql
SHIPHERO_USERNAME=your-shiphero-email
SHIPHERO_PASSWORD=your-shiphero-password
# Option 1: static access token from Developer Users (expires ~28 days)
# SHIPHERO_ACCESS_TOKEN=
# Legacy alias also supported: SHIP_HERO_API
# Option 2: refresh token (preferred for scheduler)
# SHIPHERO_REFRESH_TOKEN=

# Required for inventory/order sync
SHIPHERO_WAREHOUSE_ID=base64-warehouse-id
# Optional: required for inventory_replace / location-level updates
# SHIPHERO_LOCATION_ID=

# Korona → ShipHero: which field becomes ShipHero SKU (number | code | id)
SKU_FIELD=number

# Korona inventory write-back (ShipHero → Korona) and stock-read fallback when warehouse
# stocks return "not tracked". Run: npm run discover
# KORONA_INVENTORY_ID=
# KORONA_INVENTORY_LIST_ID=
# Auto-enable trackInventory on Korona products during stock sync (default on).
# KORONA_AUTO_ENABLE_STOCK_TRACKING=true
# Korona warehouse UUID for stock reads (optional; default sums all warehouses).
# KORONA_WAREHOUSE_ID=64698fab-195e-4718-83f7-b121426267a4

# Push Korona on-hand to ShipHero (inventory_replace). Set false to use receipt deltas only.
SYNC_KORONA_STOCK=true
# Products per stock cron batch (Vercel rotates pages in Supabase cursor).
STOCK_SYNC_BATCH_SIZE=150

# Sync tuning
SYNC_PAGE_SIZE=100
PRODUCT_SYNC_REVISION_CURSOR=
RECEIPT_SYNC_REVISION_CURSOR=
CUSTOMER_ORDER_SYNC_REVISION_CURSOR=
SHIPHERO_ORDERS_UPDATED_FROM=

# Scheduler (cron expressions, UTC). Used by npm start
CRON_PRODUCTS=0 */4 * * *
CRON_INVENTORY=*/15 * * * *
CRON_ORDERS=*/10 * * * *
# Local scheduler stock cron (matches Vercel /api/cron/stock every 15 min)
CRON_STOCK=*/15 * * * *

# Database — Supabase (Vercel/production) or local SQLite
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# On Vercel, force Supabase (SQLite does not persist on serverless):
# DATABASE_PROVIDER=supabase
# Optional: Postgres URI to auto-apply schema (Settings → Database → URI)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
# Force provider: supabase | sqlite
# DATABASE_PROVIDER=supabase
DATABASE_PATH=./data/sync.db

# Vercel Cron (auto-sync). Set in Vercel → Environment Variables.
# Vercel sends: Authorization: Bearer <CRON_SECRET>
# CRON_SECRET=MerchantCron_2026_xK9mP2qR7vL

# Dashboard UI (npm run ui) — required to protect the site
DASHBOARD_PORT=3847
DASHBOARD_PASSWORD=change-me
# IANA timezone for displayed dates (default: America/Los_Angeles = US Pacific)
DISPLAY_TIMEZONE=America/Los_Angeles
# Optional: separate cookie signing secret (defaults to DASHBOARD_PASSWORD)
# DASHBOARD_AUTH_SECRET=

# ShipHero generic label print (dashboard Print Label button)
# LABEL_PRINT_CARRIER=genericlabel
# LABEL_PRINT_METHOD=genericlabel
# LABEL_PRINT_WEIGHT=0.0625
# LABEL_PRINT_HEIGHT=1
# LABEL_PRINT_WIDTH=1
# LABEL_PRINT_LENGTH=1
# LABEL_PRINT_INVOICE=false
