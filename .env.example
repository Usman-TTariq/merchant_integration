# Korona Cloud API v3
KORONA_BASE_URL=https://185.koronacloud.com/web/api/v3
KORONA_ACCOUNT_ID=your-account-uuid
KORONA_USERNAME=your-api-login
KORONA_PASSWORD=your-api-password

# ShipHero GraphQL Public API
SHIPHERO_AUTH_URL=https://public-api.shiphero.com/auth/token
SHIPHERO_REFRESH_URL=https://public-api.shiphero.com/auth/refresh
SHIPHERO_GRAPHQL_URL=https://public-api.shiphero.com/graphql
SHIPHERO_USERNAME=your-shiphero-email
SHIPHERO_PASSWORD=your-shiphero-password
# Option 1: static access token from Developer Users (expires ~28 days)
# SHIPHERO_ACCESS_TOKEN=
# Legacy alias also supported: SHIP_HERO_API
# Option 2: refresh token (preferred for scheduler)
# SHIPHERO_REFRESH_TOKEN=

# Required for inventory/order sync
SHIPHERO_WAREHOUSE_ID=base64-warehouse-id
# Optional: required for inventory_replace / location-level updates
# SHIPHERO_LOCATION_ID=

# Korona → ShipHero: which field becomes ShipHero SKU (number | code | id)
SKU_FIELD=number

# Korona inventory write-back (ShipHero → Korona). Leave empty to skip Korona stock updates.
# KORONA_INVENTORY_ID=
# KORONA_INVENTORY_LIST_ID=

# Sync tuning
SYNC_PAGE_SIZE=100
PRODUCT_SYNC_REVISION_CURSOR=
RECEIPT_SYNC_REVISION_CURSOR=
CUSTOMER_ORDER_SYNC_REVISION_CURSOR=
SHIPHERO_ORDERS_UPDATED_FROM=

# Scheduler (cron expressions, UTC). Used by npm start
CRON_PRODUCTS=0 */4 * * *
CRON_INVENTORY=*/15 * * * *
CRON_ORDERS=*/10 * * * *

# Database — Supabase (Vercel/production) or local SQLite
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional: Postgres URI to auto-apply schema (Settings → Database → URI)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
# Force provider: supabase | sqlite
# DATABASE_PROVIDER=supabase
DATABASE_PATH=./data/sync.db

# Dashboard UI (npm run ui)
DASHBOARD_PORT=3847
